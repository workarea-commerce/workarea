# Example environment variables for docker-compose.yml
#
# Copy to .env (ignored by git; see .gitignore) to avoid docker compose warnings about unset vars.
#
#   cp -n .env.example .env
#
# Canonical service versions live in core/lib/workarea/version.rb

MONGODB_VERSION=4.0
MONGODB_PORT=27017

REDIS_VERSION=6.2
REDIS_PORT=6379

# Elasticsearch 6.8 images are published under Elastic's registry.
ELASTICSEARCH_VERSION=6.8.23
ELASTICSEARCH_PORT=9200
