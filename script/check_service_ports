#!/usr/bin/env sh

# Preflight check for common Workarea service ports.
#
# Exits 0 if all expected ports are:
#   - free, OR
#   - published by Workarea docker containers (best-effort detection)
#
# Exits non-zero if any port is already in use by something else.
#
# Read-only and safe.

set -eu

# Ensure common admin tools are discoverable on macOS/Linux.
PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

cd "$(dirname "$0")/.."

PORTS="6379:redis 27017:mongo 9200:elasticsearch"

have() { command -v "$1" >/dev/null 2>&1; }

# Best-effort: Docker may not be installed/running; still report port owners.
DOCKER_OK=0
if have docker; then
  if docker info >/dev/null 2>&1; then
    DOCKER_OK=1
  fi
fi

port_listening() {
  port="$1"

  if have lsof; then
    # Any LISTENing TCP socket on this port?
    # Output: COMMAND PID USER ...
    lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk 'NR>1 { print; exit 0 } END { exit 1 }'
    return $?
  fi

  # Fallback: use ss if present (Linux).
  if have ss; then
    # Example: LISTEN 0 4096 127.0.0.1:6379 ... users:("redis-server",pid=...)
    ss -ltnp 2>/dev/null | awk -v p=":${port}" '$0 ~ p { print; exit 0 } END { exit 1 }'
    return $?
  fi

  # Fallback: netstat (macOS/Linux) (no owner info).
  if have netstat; then
    netstat -an 2>/dev/null | awk -v p=".${port} " '($0 ~ /LISTEN/ || $0 ~ /LISTENING/) && $0 ~ p { print "(listening)"; exit 0 } END { exit 1 }'
    return $?
  fi

  return 2
}

docker_containers_publishing_port() {
  port="$1"

  [ "$DOCKER_OK" -eq 1 ] || return 1

  # Output: name (one per line). Best-effort parse of `docker ps` PORTS column.
  # Matches e.g. "0.0.0.0:6379->6379/tcp" or "127.0.0.1:9200->9200/tcp".
  docker ps --format '{{.Names}}|{{.Ports}}' 2>/dev/null \
    | awk -F'|' -v p=":${port}->" '$2 ~ p { print $1 }'
}

is_workarea_container() {
  name="$1"

  # Heuristic 1: common compose-generated name prefix.
  echo "$name" | grep -Eq '^workarea-' && return 0

  # Heuristic 2: compose project label.
  if [ "$DOCKER_OK" -eq 1 ]; then
    project="$(docker inspect --format '{{ index .Config.Labels "com.docker.compose.project" }}' "$name" 2>/dev/null || true)"
    [ "$project" = "workarea" ] && return 0
  fi

  return 1
}

print_header() {
  echo "Workarea service port preflight"
  echo "Repo: $(pwd)"
  echo

  if [ "$DOCKER_OK" -eq 1 ]; then
    echo "Docker: OK"
  else
    if have docker; then
      echo "Docker: unavailable (is Docker running?)"
    else
      echo "Docker: not installed"
    fi
  fi

  echo
}

print_header

EXIT=0

for entry in $PORTS; do
  port="$(echo "$entry" | cut -d: -f1)"
  label="$(echo "$entry" | cut -d: -f2)"

  echo "Port ${port} (${label})"

  listen_line=""
  if listen_line="$(port_listening "$port" 2>/dev/null)"; then
    echo "  listening: yes"

    # Best-effort owner info
    if [ -n "$listen_line" ]; then
      # lsof: COMMAND PID USER ...
      cmd="$(echo "$listen_line" | awk '{print $1}')"
      pid="$(echo "$listen_line" | awk '{print $2}')"
      usr="$(echo "$listen_line" | awk '{print $3}')"
      if [ -n "$cmd" ] && [ -n "$pid" ]; then
        echo "  owner: ${cmd} (pid ${pid}, user ${usr})"
      else
        echo "  owner: (unknown)"
      fi
    else
      echo "  owner: (unknown)"
    fi

    containers_lines="$(docker_containers_publishing_port "$port" 2>/dev/null || true)"
    containers="$(echo "$containers_lines" | tr '\n' ' ' | sed 's/[[:space:]]\+$//')"
    if [ -n "$containers_lines" ]; then
      echo "  docker: publishing containers: ${containers}"
    else
      echo "  docker: (none detected)"
    fi

    # Fail-safe: assume conflict whenever a port is listening.
    # Only clear to OK if we can positively confirm a Workarea container owns it.
    ok=0

    if [ "$DOCKER_OK" -eq 1 ] && [ -n "$containers_lines" ]; then
      for c in $containers_lines; do
        if is_workarea_container "$c"; then
          ok=1
          break
        fi
      done
    fi

    if [ "$ok" -eq 1 ]; then
      echo "  status: ok"
    else
      echo "  status: conflict"
      echo "  recommendation:"
      echo "    - If these ports should be free: stop the conflicting service."
      echo "    - If this is a stale Workarea stack: run 'docker compose down' from the repo root."
      echo "    - If Docker isn't running: start Docker Desktop, then re-run this script."
      EXIT=1
    fi
  else
    rc=$?
    if [ "$rc" -eq 2 ]; then
      echo "  listening: unknown (no lsof/ss/netstat available)"
      echo "  status: ok (unable to verify; no port tools available)"
      # Be conservative about safety: unknown tooling should not block users.
    else
      echo "  listening: no"
      echo "  status: ok (free)"
    fi
  fi

  echo

done

exit "$EXIT"
